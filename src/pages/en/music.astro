---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/translations";
import { base } from "../../utils/url";
const tr = t("en");

// Spotify embed height: 152px base + 70px per track (update releaseCount when adding songs)
const releaseCount = 4;
const spotifyHeight = 152 + releaseCount * 70;
---

<Layout
    title={tr.musikPage.title}
    description={tr.musikPage.description}
    lang="en"
>
    <div class="pt-32 pb-6 max-w-7xl mx-auto px-6">
        <div class="mb-20">
            <p
                class="text-xs tracking-[0.3em] uppercase text-[var(--accent)] mb-4"
            >
                <span class="accent-line"></span>{tr.musikPage.sectionLabel}
            </p>
            <h1 class="font-display text-6xl md:text-8xl font-light">
                {tr.musikPage.heading}
            </h1>
        </div>

        <section>
            <div class="flex items-center justify-between mb-10">
                <p
                    class="text-xs tracking-[0.3em] uppercase text-[var(--muted)]"
                >
                    Releases
                </p>
                <div class="flex gap-3">
                    <a
                        href="https://open.spotify.com/artist/5KbZOwHcpetbnxhrDScWlp"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-ghost"
                    >
                        Spotify ↗
                    </a>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    [
                        {
                            title: "Upcoming Release · Proud",
                            year: "2026",
                            type: "Single",
                            cover: "https://jaeckmusic.com/_assets/media/385834e51173ab4ea20990631b3fc3cd.png",
                            spotify: "https://save-it.cc/smg/proud",
                        },
                        {
                            title: "Latest Release · Once You'd Love Me",
                            year: "2026",
                            type: "Single",
                            cover: "https://jaeckmusic.com/_assets/media/634ce2db74bea558963a2163947468aa.png",
                            spotify:
                                "https://open.spotify.com/album/55LJR1RMBAatVSfNR4ZH5c",
                        },
                        {
                            title: "The JÆCK Collection",
                            year: "",
                            type: "Playlist",
                            cover: "https://jaeckmusic.com/_assets/media/3ee70a4af2777447809304992de2b0ef.jpg",
                            spotify:
                                "https://open.spotify.com/playlist/6dpcaP6uXtmwWLFVxLEt8o",
                        },
                    ].map(({ title, year, type, cover, spotify }) => (
                        <a
                            href={spotify}
                            target={
                                spotify.startsWith("http")
                                    ? "_blank"
                                    : undefined
                            }
                            rel={
                                spotify.startsWith("http")
                                    ? "noopener noreferrer"
                                    : undefined
                            }
                            class="group block bg-[var(--surface)] border border-[var(--border)] hover:border-[var(--accent)] transition-colors duration-300"
                        >
                            <div class="img-reveal aspect-square overflow-hidden">
                                <img
                                    src={cover}
                                    alt={title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    loading="lazy"
                                    width="400"
                                    height="400"
                                />
                            </div>
                            <div class="p-5">
                                <p class="text-xs tracking-widest uppercase text-[var(--accent)] mb-1">
                                    {type} {year && `· ${year}`}
                                </p>
                                <p class="font-display text-2xl font-light text-[var(--text)]">
                                    {title}
                                </p>
                            </div>
                        </a>
                    ))
                }
            </div>
        </section>

        <div class="border-t border-[var(--border)] my-16"></div>

        <section class="mb-8">
            <p
                class="text-xs tracking-[0.3em] uppercase text-[var(--muted)] mb-8"
            >
                {tr.musikPage.spotifyNote}
            </p>
            <!-- Spotify Artist Embed (height = 152 + releaseCount * 80) -->
            <iframe
                style="border-radius:0"
                src="https://open.spotify.com/embed/artist/5KbZOwHcpetbnxhrDScWlp?utm_source=generator&theme=0"
                width="100%"
                height={spotifyHeight}
                frameBorder="0"
                allowfullscreen
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                title="JÆCK on Spotify"></iframe>
        </section>
    </div>
</Layout>
