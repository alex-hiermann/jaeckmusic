---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/translations";
import { base } from "../../utils/url";
const tr = t("en");
---

<Layout title={tr.datenschutz.title} noindex={true} lang="en">
    <div class="pt-32 pb-20 max-w-3xl mx-auto px-6">
        <h1 class="font-display text-5xl md:text-6xl font-light mb-12">
            {tr.datenschutz.heading}
        </h1>

        <div
            class="space-y-10 text-[var(--muted)] font-light leading-relaxed text-sm"
        >
            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    1. Controller
                </p>
                <p>
                    JÆCK · Jakob Trcka · <a
                        href="mailto:contact@jaeckmusic.com"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >contact@jaeckmusic.com</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    2. Hosting - GitHub Pages
                </p>
                <p>
                    This website is hosted on GitHub Pages (GitHub, Inc., 88
                    Colin P. Kelly Jr. St., San Francisco, CA 94107, USA). When
                    you visit, technical data (IP address, date/time, page
                    accessed) is automatically collected. Legal basis: Art.
                    6(1)(f) GDPR (legitimate interest in secure operation).
                    Details: <a
                        href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >GitHub Privacy Statement ↗</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    3. Contact Form (Formspree)
                </p>
                <p>
                    The contact form uses Formspree (Formspree Inc., Baltimore,
                    MD, USA). Submitted data (name, email, message) is used
                    solely to respond to your inquiry and is not passed on to
                    third parties. Legal basis: Art. 6(1)(b) GDPR. Details: <a
                        href="https://formspree.io/legal/privacy-policy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >Formspree Privacy ↗</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    4. Embedded Content
                </p>
                <p class="mb-3">
                    <strong class="text-[var(--text)] font-normal"
                        >YouTube (Google LLC):</strong
                    > Videos are embedded via youtube-nocookie.com. When played, YouTube
                    may transfer data per their privacy policy.
                    <a
                        href="https://policies.google.com/privacy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >Google Privacy ↗</a
                    >
                </p>
                <p>
                    <strong class="text-[var(--text)] font-normal"
                        >Spotify (Spotify AB):</strong
                    > Music players are embedded via open.spotify.com. When played,
                    data may be transferred to Spotify.
                    <a
                        href="https://www.spotify.com/privacy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >Spotify Privacy ↗</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    5. Google Fonts
                </p>
                <p>
                    This website loads fonts from Google Fonts (Google LLC,
                    Mountain View, CA, USA). Your IP address is transmitted to
                    Google. Legal basis: Art. 6(1)(f) GDPR.
                    <a
                        href="https://policies.google.com/privacy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >Google Privacy ↗</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    6. Your Rights
                </p>
                <p>
                    You have the right to access (Art. 15 GDPR), rectification
                    (Art. 16), erasure (Art. 17), restriction of processing
                    (Art. 18), data portability (Art. 20) and objection (Art. 21
                    GDPR). You may lodge a complaint with the Austrian Data
                    Protection Authority (<a
                        href="https://www.dsb.gv.at"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >dsb.gv.at ↗</a
                    >).
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    7. Cookies &amp; Tracking
                </p>
                <p>
                    This website uses no cookies of its own and no tracking. No
                    analytics or advertising tools are employed.
                </p>
            </section>
        </div>
    </div>
</Layout>
