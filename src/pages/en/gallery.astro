---

<Layout
    title={tr.galeriePage.title}
    description={tr.galeriePage.description}
    lang="en"
>
    <div class="pt-32 pb-20 max-w-7xl mx-auto px-6">
        <div class="mb-16">
            <p
                class="text-xs tracking-[0.3em] uppercase text-[var(--accent)] mb-4"
            >
                <span class="accent-line"></span>{tr.galeriePage.sectionLabel}
            </p>
            <h1 class="font-display text-6xl md:text-8xl font-light">
                {tr.galeriePage.heading}
            </h1>
        </div>
        <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
            {
                images.map(({ src, alt }) => (
                    <div class="img-reveal break-inside-avoid">
                        <img
                            src={src}
                            alt={alt}
                            class="w-full h-auto object-cover"
                            loading="lazy"
                            width="600"
                            height="800"
                        />
                    </div>
                ))
            }
        </div>
    </div>
</Layout>
