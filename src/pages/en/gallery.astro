        alt: "JÆCK Photo 7",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/2ad8e33235d66c48fcadb29df4750519.jpg",
        alt: "JÆCK Photo 8",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/9dbf8176b1790f849ce0ddcba53b84b2.jpg",
        alt: "JÆCK Photo 9",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/9cbd50704f4b562881c18442e222923b.jpg",
        alt: "JÆCK Photo 10",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/e2dc8c91dbc7bbed76cbe9ab7a819fec.jpg",
        alt: "JÆCK Photo 11",
    },
