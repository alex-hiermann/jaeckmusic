    {
        src: "https://jaeckmusic.com/_assets/media/d38a4328c41fca6800afc3664269cd42.jpg",
        alt: "JÆCK Photo 3",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/40d4279802b1c6b223d1bf424a76cb39.jpg",
        alt: "JÆCK Photo 4",
    },
    {
        src: "https://jaeckmusic.com/_assets/media/cf4d43ae80d357f563b0f60540cf5220.jpg",
        alt: "JÆCK Photo 5",
    },
    {
