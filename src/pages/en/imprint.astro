---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/translations";
import { base } from "../../utils/url";
const tr = t("en");
---

<Layout title={tr.impressum.title} noindex={true} lang="en">
    <div class="pt-32 pb-20 max-w-3xl mx-auto px-6">
        <h1 class="font-display text-5xl md:text-6xl font-light mb-12">
            {tr.impressum.heading}
        </h1>

        <div
            class="space-y-10 text-[var(--muted)] font-light leading-relaxed text-sm"
        >
            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    Information pursuant to § 5 ECG
                </p>
                <p class="text-[var(--text)] font-normal mb-2">JÆCK</p>
                <p>
                    [Full Name]<br />
                    [Street Address]<br />
                    [ZIP City], Austria
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    Contact
                </p>
                <p>
                    Email: <a
                        href="mailto:contact@jaeckmusic.com"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >contact@jaeckmusic.com</a
                    ><br />
                    Website: <a
                        href="https://jaeckmusic.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >jaeckmusic.com ↗</a
                    >
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    Copyright
                </p>
                <p>
                    All content published on this website (texts, photos,
                    videos, music) is subject to Austrian copyright law. Any use
                    not expressly permitted by copyright law requires prior
                    written consent.
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    Web Development
                </p>
                <p>
                    This website was developed by&nbsp;
                    <a
                        href="https://github.com/alex-hiermann"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[var(--text)] hover:text-[var(--accent)] transition-colors"
                        >alex-hiermann ↗</a
                    >.
                </p>
            </section>

            <section class="border-t border-[var(--border)] pt-8">
                <p
                    class="text-xs tracking-widest uppercase text-[var(--accent)] mb-4"
                >
                    Disclaimer
                </p>
                <p>
                    The content of this website has been compiled with the
                    utmost care. We cannot, however, guarantee the accuracy,
                    completeness or timeliness of the content. As a service
                    provider we are responsible for our own content on these
                    pages in accordance with general laws.
                </p>
            </section>
        </div>
    </div>
</Layout>
