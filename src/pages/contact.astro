---
import Layout from "../layouts/Layout.astro";
import { t } from "../i18n/translations";
import { base } from "../utils/url";
const tr = t("de");
---

<Layout
    title={tr.kontaktPage.title}
    description={tr.kontaktPage.description}
    lang="de"
>
    <div class="pt-32 pb-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32">
                <!-- Left: info -->
                <div>
                    <p
                        class="text-xs tracking-[0.3em] uppercase text-[var(--accent)] mb-4"
                    >
                        <span class="accent-line"></span>{
                            tr.kontaktPage.sectionLabel
                        }
                    </p>
                    <h1
                        class="font-display text-5xl md:text-6xl font-light mb-8"
                    >
                        {tr.kontaktPage.heading}
                    </h1>
                    <p
                        class="text-[var(--muted)] leading-relaxed font-light mb-12 max-w-md"
                    >
                        {tr.kontaktPage.intro}
                    </p>

                    <!-- Info items -->
                    <div class="space-y-6 mb-12">
                        <div class="border-t border-[var(--border)] pt-6">
                            <p
                                class="text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                Booking
                            </p>
                            <a
                                href="mailto:contact@jaeckmusic.com"
                                class="text-[var(--text)] hover:text-[var(--accent)] transition-colors duration-200 font-light"
                            >
                                contact@jaeckmusic.com
                            </a>
                        </div>
                        <div class="border-t border-[var(--border)] pt-6">
                            <p
                                class="text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                Website
                            </p>
                            <a
                                href="https://jaeckmusic.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-[var(--text)] hover:text-[var(--accent)] transition-colors duration-200 font-light"
                            >
                                jaeckmusic.com ↗
                            </a>
                        </div>
                    </div>

                    <!-- Decorative image -->
                    <div class="img-reveal hidden lg:block">
                        <img
                            src="https://jaeckmusic.com/_assets/media/da9f5b16dae7932115b048e06d8fc25e.jpg"
                            alt="JÆCK"
                            class="w-full aspect-video object-cover"
                            loading="lazy"
                            width="600"
                            height="338"
                        />
                    </div>
                </div>

                <!-- Right: form -->
                <div>
                    <form
                        id="contact-form"
                        action="https://formspree.io/f/xnjwnrak"
                        method="POST"
                        class="space-y-6"
                        novalidate
                    >
                        <!-- Honeypot anti-spam -->
                        <input
                            type="text"
                            name="_gotcha"
                            style="display:none"
                            tabindex="-1"
                            autocomplete="off"
                        />

                        <div>
                            <label
                                for="name"
                                class="block text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                {tr.kontaktPage.name} *
                            </label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                autocomplete="name"
                                class="form-input"
                                placeholder="Dein Name"
                            />
                        </div>

                        <div>
                            <label
                                for="email"
                                class="block text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                {tr.kontaktPage.email} *
                            </label>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                autocomplete="email"
                                class="form-input"
                                placeholder="deine@email.com"
                            />
                        </div>

                        <div>
                            <label
                                for="subject"
                                class="block text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                {tr.kontaktPage.subject}
                            </label>
                            <input
                                type="text"
                                id="subject"
                                name="subject"
                                class="form-input"
                                placeholder="z.B. Booking Anfrage"
                            />
                        </div>

                        <div>
                            <label
                                for="message"
                                class="block text-xs tracking-widest uppercase text-[var(--muted)] mb-2"
                            >
                                {tr.kontaktPage.message} *
                            </label>
                            <textarea
                                id="message"
                                name="message"
                                required
                                rows="6"
                                class="form-input"
                                placeholder="Deine Nachricht..."></textarea>
                        </div>

                        <button
                            type="submit"
                            class="btn-primary w-full justify-center"
                        >
                            {tr.kontaktPage.send}
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M5 12h14"></path><path
                                    d="m12 5 7 7-7 7"></path></svg
                            >
                        </button>

                        <p class="text-xs text-[var(--muted)] text-center">
                            Oder direkt per E-Mail:
                            <a
                                href="mailto:contact@jaeckmusic.com"
                                class="text-[var(--accent)] hover:underline"
                            >
                                contact@jaeckmusic.com
                            </a>
                        </p>

                        <!-- Success / error messages -->
                        <div
                            id="form-success"
                            class="hidden p-4 border border-green-800 bg-green-950/30 text-green-400 text-sm text-center"
                        >
                            {tr.kontaktPage.success}
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    const form = document.getElementById(
        "contact-form",
    ) as HTMLFormElement | null;
    const successMsg = document.getElementById("form-success");

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        try {
            const res = await fetch(form.action, {
                method: "POST",
                body: data,
                headers: { Accept: "application/json" },
            });
            if (res.ok) {
                form.reset();
                successMsg?.classList.remove("hidden");
            }
        } catch {
            // silent fail - user can still email directly
        }
    });
</script>
